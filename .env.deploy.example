AZURE_RESOURCE_GROUP=moscript-rg
AZURE_CONTAINER_APP_NAME=moscript
AZURE_ACR_NAME=moscriptacr2026
AZURE_IMAGE_REPOSITORY=moscript
DOCKER_PLATFORM=linux/amd64
AZURE_BUILD_MODE=acr

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Required: a long random string used to sign session cookies. DO NOT reuse GOOGLE_CLIENT_SECRET.
# Generate with: openssl rand -hex 32
AUTH_SECRET=
MOSCRIPT_APP_URL=

# Required: comma-separated email allowlist for /admin access.
# If left empty, NO ONE can access /admin (fail-closed).
# Example: MOSCRIPT_ADMIN_EMAILS=alice@example.com,bob@example.com
MOSCRIPT_ADMIN_EMAILS=
